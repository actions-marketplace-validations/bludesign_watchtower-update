{
  "name": "watchtower-action",
  "version": "4.0.0",
  "private": true,
  "description": "Trigger Docker container updates via Watchtower HTTP API from GitHub Actions",
  "main": "lib/main.js",
  "scripts": {
    "build": "tsc",
    "format": "prettier --write '**/*.ts'",
    "format-check": "prettier --check '**/*.ts'",
    "lint": "eslint src/**/*.ts",
    "package": "ncc build --source-map --license licenses.txt",
    "all": "yarn build && yarn format && yarn lint && yarn package"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bludesign/watchtower-update.git"
  },
  "keywords": [
    "actions",
    "docker",
    "watchtower",
    "deploy"
  ],
  "author": "bludesign",
  "license": "MIT",
  "dependencies": {
    "@actions/core": "^1.10.0",
    "axios": "^1.4.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@typescript-eslint/parser": "^5.59.2",
    "@vercel/ncc": "^0.38.4",
    "eslint": "^8.39.0",
    "eslint-plugin-github": "^4.7.0",
    "eslint-plugin-prettier": "^5.0.0",
    "js-yaml": "^4.1.0",
    "prettier": "^2.8.8",
    "typescript": "^5.0.4"
  }
}
